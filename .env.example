# =========================================================
# USPS AMIE environment configuration
# Copy to .env and fill in values. Never commit .env.
# =========================================================

# Application
APP_NAME=usps-amie-chatbot
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# LLM Provider: ollama | anthropic | mock
LLM_PROVIDER=mock
LLM_MODEL=claude-opus-4-5
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2

# Anthropic
ANTHROPIC_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1

# RAG / Redis
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
KB_PATH=/app/data/knowledge_base
RETRIEVAL_TOP_K=5

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_VECTOR_INDEX=amie:vectors
REDIS_CONVO_PREFIX=amie:conv:
REDIS_CACHE_TTL_SECONDS=3600

# Address Verification Tool
ADDRESS_VERIFIER=mock
USPS_API_BASE_URL=https://secure.shippingapis.com
USPS_API_USER_ID=
USPS_API_PASSWORD=

# Security
AUTH_ENABLED=false
JWT_AUDIENCE=usps-amie
JWT_ISSUER=

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_TITLE=USPS AMIE
