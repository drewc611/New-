# =========================================================
# USPS AMIE environment configuration
# Copy to .env and fill in values. Never commit .env.
# =========================================================

# Application
APP_NAME=usps-amie-chatbot
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM Provider: ollama | anthropic | mock
# For a Windows local build, use `ollama` and run Ollama Desktop
# from https://ollama.com/download/windows. AMIE will auto-pull the
# configured model on first boot.
LLM_PROVIDER=ollama
LLM_MODEL=claude-opus-4-5
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2

# Anthropic
ANTHROPIC_API_KEY=

# Ollama
# For Windows Ollama Desktop running on the host machine use localhost.
# When the backend runs inside docker compose on Windows, switch this to
# http://host.docker.internal:11434 (or start the offline profile which
# brings up an Ollama container at http://ollama:11434).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_AUTO_PULL=true
OLLAMA_REQUEST_TIMEOUT_SECONDS=180

# RAG / Redis
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
KB_PATH=/app/data/knowledge_base
RETRIEVAL_TOP_K=5

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_VECTOR_INDEX=amie:vectors
REDIS_CONVO_PREFIX=amie:conv:
REDIS_CACHE_TTL_SECONDS=3600

# Address Verification Tool
# Options: mock | usps_api
# The mock verifier implements Publication 28 parsing locally with no
# network dependency, including secondary unit designators and Puerto
# Rico urbanization (URB) lines.
ADDRESS_VERIFIER=mock
USPS_API_BASE_URL=https://secure.shippingapis.com
USPS_API_USER_ID=
USPS_API_PASSWORD=
# Seconds before the USPS API request times out.
USPS_API_TIMEOUT_SECONDS=15

# Security
AUTH_ENABLED=false
JWT_AUDIENCE=usps-amie
JWT_ISSUER=
JWT_JWKS_URL=
JWT_ALGORITHMS=RS256
# Set to a strong random value in production, comma separated to rotate.
REQUEST_MAX_BODY_BYTES=262144

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_TITLE=USPS AMIE
