# =========================================================
# USPS AMIE environment configuration
# Copy to .env and fill in values. Never commit .env.
# =========================================================

# Application
APP_NAME=usps-amie-chatbot
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM Provider: ollama | anthropic | mock
# For a Windows local build, use `ollama` and run Ollama Desktop
# from https://ollama.com/download/windows. AMIE will auto-pull the
# configured model on first boot.
LLM_PROVIDER=ollama
LLM_MODEL=claude-opus-4-5
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2

# Anthropic
ANTHROPIC_API_KEY=

# Ollama
# For Windows Ollama Desktop running on the host machine use localhost.
# When the backend runs inside docker compose on Windows, switch this to
# http://host.docker.internal:11434 (or start the offline profile which
# brings up an Ollama container at http://ollama:11434).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_AUTO_PULL=true
OLLAMA_REQUEST_TIMEOUT_SECONDS=180

# RAG / Redis
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
KB_PATH=/app/data/knowledge_base
RETRIEVAL_TOP_K=5

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=amie
MONGO_CONVERSATIONS_COLLECTION=conversations
MONGO_VECTORS_COLLECTION=vectors
MONGO_ADDRESS_EVENTS_COLLECTION=address_events
MONGO_ADDRESS_EVENTS_CAPPED_SIZE_MB=64
MONGO_ADDRESS_EVENTS_CAPPED_MAX_DOCS=50000
# Set to true when pointing at MongoDB Atlas with a vector search index
MONGO_USE_ATLAS_VECTOR_SEARCH=false
MONGO_ATLAS_VECTOR_INDEX_NAME=vector_index

# Address Verification Tool
# Options: mock | usps_api
# The mock verifier implements Publication 28 parsing locally with no
# network dependency, including secondary unit designators and Puerto
# Rico urbanization (URB) lines.
ADDRESS_VERIFIER=mock
USPS_API_BASE_URL=https://secure.shippingapis.com
USPS_API_USER_ID=
USPS_API_PASSWORD=
# Seconds before the USPS API request times out.
USPS_API_TIMEOUT_SECONDS=15

# Security
AUTH_ENABLED=false
JWT_AUDIENCE=usps-amie
JWT_ISSUER=
JWT_JWKS_URL=
JWT_ALGORITHMS=RS256
REQUEST_MAX_BODY_BYTES=262144

# Okta / OIDC Single Sign-On
# To enable Okta SSO:
#   1. Create a SPA (Single Page Application) in the Okta admin console
#   2. Add redirect URI http://localhost:5173/auth/callback for dev
#   3. Add post-logout redirect http://localhost:5173
#   4. Create an Authorization Server (or use the default at /oauth2/default)
#   5. Set AUTH_ENABLED=true, OKTA_ENABLED=true and fill the values below
OKTA_ENABLED=false
OKTA_ISSUER=
OKTA_CLIENT_ID=
OKTA_AUDIENCE=api://usps-amie
OKTA_SCOPES=openid profile email offline_access

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_TITLE=USPS AMIE

# Optional Okta SPA fallbacks. When set, the SPA can start the login
# flow without first fetching /api/auth/config. These must match the
# backend OKTA_* values above.
VITE_OKTA_ENABLED=false
VITE_OKTA_ISSUER=
VITE_OKTA_CLIENT_ID=
VITE_OKTA_AUDIENCE=api://usps-amie
VITE_OKTA_SCOPES=openid profile email offline_access
VITE_OKTA_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_OKTA_POST_LOGOUT_URI=http://localhost:5173
